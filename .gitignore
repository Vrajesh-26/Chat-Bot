############################
# Java / Maven
############################
target/
*.class
*.jar
*.war
*.ear

# Allow nested targets (Maven multi-module safety)
!**/src/main/**/target/
!**/src/test/**/target/

############################
# Maven Wrapper
############################
.mvn/wrapper/maven-wrapper.jar

############################
# IntelliJ IDEA
############################
.idea/
*.iws
*.iml
*.ipr
out/

############################
# VS Code
############################
.vscode/
.vscode/*
!.vscode/extensions.json
.history/

############################
# Spring / STS
############################
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

############################
# NetBeans
############################
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

############################
# Logs
############################
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

############################
# Environment / Secrets
############################
.env
.env.*
*.key
*.pem
*.crt
HELP.md

# Spring config (DO NOT COMMIT SECRETS)
src/main/resources/application.properties
src/main/resources/application.yml
*.yml

############################
# Node / Frontend (future)
############################
node_modules/
dist
dist-ssr
*.local

############################
# OS generated files
############################
# Windows
Thumbs.db
desktop.ini
ehthumbs.db

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

############################
# Archives / Media
############################
*.zip
pic-to-understand-backend.png

############################
# Editor / Misc
############################
*.tmp
*.temp
*.bak
*.old
*.swp
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
